<edit-config>
        <target>
            <candidate/>
        </target>
        <config>
          <configure xmlns="urn:nokia.com:sros:ns:yang:sr:conf">
   
    <router>
      <router-name>Base</router-name>
      <static-routes>
        <route>
          <ip-prefix>0.0.0.0/0</ip-prefix>
          <route-type>unicast</route-type>
          <next-hop>
            <ip-address>{{.GateWay}}</ip-address>
            <admin-state>enable</admin-state>
          </next-hop>
        </route>
      </static-routes>
    </router>
    <service>
      <ies>
        <service-name>2</service-name>
        <admin-state>enable</admin-state>
        <customer>1</customer>
        <interface>
          <interface-name>mgmt_ztp</interface-name>
          <admin-state>enable</admin-state>
          <oamsave>true</oamsave>
          <sap>
            <sap-id>1/5/1:4093</sap-id>
            <admin-state>enable</admin-state>
          </sap>
          <ipv4>
            <primary>
              <address>{{.IpAddr}}</address>
              <prefix-length>{{.NetMask}}</prefix-length>
            </primary>
          </ipv4>
          <ipv6/>
        </interface>
      </ies>
      <vpls>
        <service-name>4093</service-name>
        <admin-state>enable</admin-state>
        <service-id>4093</service-id>
        <customer>1</customer>
        <v-vpls>true</v-vpls>
        <vlan>4093</vlan>
        <sap>
          <sap-id>lag-2:0</sap-id>
          <admin-state>enable</admin-state>
        </sap>
      </vpls>
    </service>
  </configure>
        </config>
    </edit-config>