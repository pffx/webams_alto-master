{
  "name": "alto",
  "version": "2.2.0",
  "private": true,
  "main": "main.js",
  "asar": false,
  "build": {
    "appId": "alto",
    "productName": "Alto",
    "win": {
      "target": [
        "nsis",
        "zip"
      ]
    },
    "extends": null,
    "extraResources": [
      {
        "from": "./back_end/AltoServer.exe",
        "to": "./AltoServer.exe"
      },
      {
        "from": "./back_end/conf/authz",
        "to": "./conf/authz"
      },
      {
        "from": "./back_end/conf/app.ini",
        "to": "./conf/app.ini"
      },
      {
        "from": "./back_end/db",
        "to": "./db"
      },
      {
        "from": "./back_end/template",
        "to": "./template"
      }
    ]
  },
  "dependencies": {
    "@nokia-csf-uxr/ccfk": "^2.2.3",
    "@reduxjs/toolkit": "^1.8.2",
    "@testing-library/jest-dom": "^5.16.4",
    "@testing-library/react": "^13.3.0",
    "@testing-library/user-event": "^13.5.0",
    "axios": "1.7.4",
    "concurrently": "^7.2.1",
    "cross-env": "^7.0.3",
    "electron-is-dev": "^2.0.0",
    "i18next": "^21.8.13",
    "react": "^18.1.0",
    "react-dom": "^18.1.0",
    "react-i18next": "^11.18.0",
    "react-redux": "^8.0.2",
    "react-router-dom": "6",
    "react-scripts": "5.0.1",
    "react-toastify": "^9.0.8",
    "redux-logger": "^3.0.6",
    "redux-persist": "^6.0.0",
    "redux-thunk": "^2.4.1",
    "wait-on": "^6.0.1",
    "web-vitals": "^2.1.4",
    "xterm": "^4.18.0",
    "xterm-addon-attach": "^0.6.0",
    "xterm-addon-fit": "^0.5.0",
    "xterm-addon-webgl": "^0.11.4"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "build:test": "dotenv -e .env.test react-scripts build",
    "build:prod": "dotenv -e .env.production react-scripts build",
    "start:test": "dotenv -e .env.test react-scripts start",
    "start:prod": "dotenv -e .env.production react-scripts start",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "gin-build": "cd ./back_end && go build -o AltoServer.exe",
    "electron": "electron .",
    "discard-electron-build": "electron-builder",
    "post-discard-electron-build": "node scripts/copy-assets.js",
    "electron-start": "concurrently \" wait-on http://localhost:3000 && electron . \" \" cross-env BROWSER=none npm start \" "
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "cpy-cli": "^6.0.0",
    "dotenv-cli": "^6.0.0",
    "electron": "^38.1.0",
    "electron-builder": "^26.0.12"
  }
}
